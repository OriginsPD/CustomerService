# Neon PostgreSQL connection string
# Get from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/vcc?sslmode=require

# Anthropic API key — get from https://console.anthropic.com
# When not set, the server falls back to built-in heuristics (no AI calls)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Server port
PORT=3001

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173


JWT_SECRET=<strong-random-secret>    # defaults to dev placeholder
STAFF_USERNAME=admin                  # defaults to "admin"
STAFF_PASSWORD=<your-password>        # defaults to "vcc2024"
