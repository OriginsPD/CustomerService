# ── Node modules (reinstalled inside container) ───────────────────────────────
node_modules/
*/node_modules/
**/node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────────
client/dist/
server/dist/
packages/*/dist/

# ── Environment files (injected at runtime via env_file or secrets) ───────────
.env
.env.*
!.env.example

# ── Drizzle migrations (run separately, not baked into image) ─────────────────
server/drizzle/
drizzle/

# ── TypeScript build info ─────────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Docker files (no need to copy these into the image) ───────────────────────
Dockerfile*
docker-compose*.yml
docker/

# ── Git and editor ────────────────────────────────────────────────────────────
.git/
.gitignore
.vscode/
.idea/
*.code-workspace

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs and coverage ────────────────────────────────────────────────────────
*.log
coverage/
